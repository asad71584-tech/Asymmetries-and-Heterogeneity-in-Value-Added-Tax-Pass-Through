def normalize_country_name(x):
    if pd.isna(x):
        return x

    value = str(x).strip()
    low = value.lower()

    if low == "germany" or "germany" in low or "deutschland" in low or value in ["DE", "DEU"]:
        return "Germany"

    if low == "austria" or "austria" in low or "österreich" in low or value in ["AT", "AUT"]:
        return "Austria"

    if low == "france" or "france" in low or value in ["FR", "FRA"]:
        return "France"

    if low == "netherlands" or "netherlands" in low or "nederland" in low or value in ["NL", "NLD"]:
        return "Netherlands"

    if low == "belgium" or "belgium" in low or "belgique" in low or "belgië" in low or value in ["BE", "BEL"]:
        return "Belgium"

    return value


def parse_month_value(x):
    if pd.isna(x):
        return None

    if isinstance(x, (pd.Timestamp, datetime)):
        if 2000 <= x.year <= 2035:
            return pd.Period(x, freq="M")

    if isinstance(x, np.datetime64):
        dt = pd.to_datetime(x)
        if 2000 <= dt.year <= 2035:
            return pd.Period(dt, freq="M")

    text = str(x).strip()

    if text == "" or text.lower() in ["nan", "none"]:
        return None

    if re.match(r"^\d{4}-\d{2}$", text):
        return pd.Period(text, freq="M")

    if re.match(r"^\d{4}M\d{2}$", text):
        return pd.Period(text.replace("M", "-"), freq="M")

    if re.match(r"^\d{4}/\d{2}$", text):
        return pd.Period(text.replace("/", "-"), freq="M")

    found = re.search(r"(20\d{2})[-/M](\d{2})", text)
    if found:
        year = found.group(1)
        month = found.group(2)
        if 1 <= int(month) <= 12:
            return pd.Period(f"{year}-{month}", freq="M")

    dt = pd.to_datetime(text, errors="coerce")
    if pd.notna(dt):
        if 2000 <= dt.year <= 2035:
            return pd.Period(dt, freq="M")

    return None


def clean_number(x):
    if pd.isna(x):
        return np.nan

    if isinstance(x, (int, float, np.integer, np.floating)):
        return float(x)

    text = str(x).strip()

    if text == "" or text.lower() in ["nan", "none", ":"]:
        return np.nan

    text = text.replace(",", ".")

    found = re.search(r"-?\d+\.?\d*", text)
    if found:
        return float(found.group(0))

    return np.nan


