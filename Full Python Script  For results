# 17. EVENT-STUDY STYLE CHECK
# ============================================================

event_results = pd.DataFrame()

event_data = baseline_data.copy()

if not event_data.empty:
    event_data["relative_month"] = (
        event_data["month"].apply(lambda x: x.ordinal) -
        pd.Period(VAT_CUT_START, freq="M").ordinal
    )

    event_data = event_data[
        (event_data["relative_month"] >= -12) &
        (event_data["relative_month"] <= 18)
    ].copy()

    event_months = sorted(event_data["relative_month"].unique())
    reference_month = -1

    event_vars = []

    for k in event_months:
        if k == reference_month:
            continue

        if k < 0:
            var_name = f"event_m{abs(k)}"
        else:
            var_name = f"event_p{k}"

        event_data[var_name] = (
            (event_data["relative_month"] == k).astype(int) *
            event_data["germany"]
        )

        event_vars.append(var_name)

    if len(event_vars) > 0:
        event_formula = (
            "dlog_hicp ~ "
            + " + ".join(event_vars)
            + " + C(country) + C(category) + C(month_str)"
        )

        event_model = run_ols(
            event_formula,
            event_data,
            "Event-study style model"
        )

        if event_model is not None:
            event_rows = []

            for k in event_months:
                if k == reference_month:
                    continue

                if k < 0:
                    var_name = f"event_m{abs(k)}"
                else:
                    var_name = f"event_p{k}"

                if var_name in event_model.params.index:
                    p = event_model.pvalues.get(var_name, np.nan)

                    event_rows.append({
                        "relative_month": k,
                        "calendar_month": str(pd.Period(VAT_CUT_START, freq="M") + k),
                        "coef": event_model.params.get(var_name, np.nan),
                        "std_error": event_model.bse.get(var_name, np.nan),
                        "p_value": p,
                        "significance": significance_stars(p)
                    })

            event_results = pd.DataFrame(event_rows)
            event_results = safe_round_df(
                event_results,
                ["coef", "std_error", "p_value"],
                6
            )

add_table("EVENT-STUDY STYLE RESULTS", event_results)


