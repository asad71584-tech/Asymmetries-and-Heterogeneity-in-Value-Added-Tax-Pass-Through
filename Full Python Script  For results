def make_correlation_table(data, value_col, check_type):
    rows = []

    for category in ALL_ANALYSIS_CATEGORIES:
        cat_df = data[data["category"] == category].copy()

        wide = cat_df.pivot_table(
            index="month",
            columns="country",
            values=value_col,
            aggfunc="mean"
        )

        if "Germany" not in wide.columns:
            continue

        for country in CONTROL_COUNTRIES:
            if country in wide.columns:
                corr = wide["Germany"].corr(wide[country])
                rows.append({
                    "check_type": check_type,
                    "category": category,
                    "comparison": f"Germany vs {country}",
                    "correlation": corr
                })

        control_cols = [c for c in CONTROL_COUNTRIES if c in wide.columns]

        if len(control_cols) > 0:
            wide["Average controls"] = wide[control_cols].mean(axis=1)
            corr_avg = wide["Germany"].corr(wide["Average controls"])

            rows.append({
                "check_type": check_type,
                "category": category,
                "comparison": "Germany vs average controls",
                "correlation": corr_avg
            })

    pooled = data[data["category"].isin(CORE_FOOD_CATEGORIES)].copy()
    pooled = pooled.groupby(["country", "month"], as_index=False)[value_col].mean()

    wide = pooled.pivot_table(
        index="month",
        columns="country",
        values=value_col
    )

    if "Germany" in wide.columns:
        for country in CONTROL_COUNTRIES:
            if country in wide.columns:
                corr = wide["Germany"].corr(wide[country])
                rows.append({
                    "check_type": check_type,
                    "category": "Core food pooled",
                    "comparison": f"Germany vs {country}",
                    "correlation": corr
                })

        control_cols = [c for c in CONTROL_COUNTRIES if c in wide.columns]

        if len(control_cols) > 0:
            wide["Average controls"] = wide[control_cols].mean(axis=1)
            corr_avg = wide["Germany"].corr(wide["Average controls"])

            rows.append({
                "check_type": check_type,
                "category": "Core food pooled",
                "comparison": "Germany vs average controls",
                "correlation": corr_avg
            })

    result = pd.DataFrame(rows)
    result = safe_round_df(result, ["correlation"], 3)

    return result


