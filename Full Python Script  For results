def read_eurostat_sheet_exact(excel_file, sheet_name):
    """
    Reads your exact Excel layout.

    Structure found from debug:
    - row 8 contains TIME and months
    - row 9 contains GEO (Labels)
    - rows 10-14 contain Belgium, Germany, France, Netherlands, Austria
    - months are in columns like 1, 3, 5, 7...
    - blank columns are between data columns
    """

    raw = pd.read_excel(excel_file, sheet_name=sheet_name, header=None)
    raw = raw.dropna(how="all")
    raw = raw.dropna(axis=1, how="all")
    raw = raw.reset_index(drop=True)

    min_month = pd.Period(START_DATE, freq="M")
    max_month = pd.Period(END_DATE, freq="M")

    # ------------------------------------------------------------
    # Find row containing TIME and months
    # ------------------------------------------------------------

    time_row = None
    month_cols = {}
    best_month_count = 0

    for r in range(raw.shape[0]):
        temp_month_cols = {}

        for c in range(raw.shape[1]):
            m = parse_month_value(raw.iloc[r, c])
            if m is not None and min_month <= m <= max_month:
                temp_month_cols[c] = m

        if len(temp_month_cols) > best_month_count:
            best_month_count = len(temp_month_cols)
            time_row = r
            month_cols = temp_month_cols

    if time_row is None or len(month_cols) == 0:
        raise ValueError(f"No month row found in sheet: {sheet_name}")

    # ------------------------------------------------------------
    # Find country rows
    # ------------------------------------------------------------

    country_rows = {}

    for r in range(time_row + 1, raw.shape[0]):
        for c in range(raw.shape[1]):
            country = normalize_country_name(raw.iloc[r, c])
            if country in COUNTRIES_KEEP:
                country_rows[r] = country
                break

    if len(country_rows) == 0:
        raise ValueError(f"No country rows found in sheet: {sheet_name}")

    # ------------------------------------------------------------
    # Build long panel
    # ------------------------------------------------------------

    rows = []

    for r, country in country_rows.items():
        for c, month in month_cols.items():
            value = clean_number(raw.iloc[r, c])

            if pd.notna(value):
                rows.append({
                    "country": country,
                    "month": month,
                    "category": sheet_name.strip(),
                    "hicp_index": value
                })

    df = pd.DataFrame(rows)

    if df.empty:
        raise ValueError(f"No numeric HICP values found in sheet: {sheet_name}")

    print(
        f"OK: {sheet_name} | time row: {time_row} | months found: {len(month_cols)} | "
        f"countries found: {len(country_rows)} | observations: {len(df)}"
    )

    return df


