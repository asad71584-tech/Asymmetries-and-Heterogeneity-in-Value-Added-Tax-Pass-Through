def significance_stars(p):
    if pd.isna(p):
        return ""
    if p < 0.01:
        return "***"
    if p < 0.05:
        return "**"
    if p < 0.10:
        return "*"
    return ""


def regression_key_table(model, model_name):
    keys = [
        "germany_during",
        "germany_post",
        "germany_during_bread",
        "germany_post_bread",
        "germany_during_food",
        "germany_post_food"
    ]

    rows = []

    for key in keys:
        if key in model.params.index:
            p = model.pvalues.get(key, np.nan)

            rows.append({
                "model": model_name,
                "variable": key,
                "coef": model.params.get(key, np.nan),
                "std_error": model.bse.get(key, np.nan),
                "t_value": model.tvalues.get(key, np.nan),
                "p_value": p,
                "significance": significance_stars(p)
            })

    result = pd.DataFrame(rows)

    if not result.empty:
        result = safe_round_df(result, ["coef", "std_error", "t_value", "p_value"], 6)

    return result


def full_regression_table(model, model_name):
    rows = []

    for var in model.params.index:
        p = model.pvalues.get(var, np.nan)

        rows.append({
            "model": model_name,
            "variable": var,
            "coef": model.params.get(var, np.nan),
            "std_error": model.bse.get(var, np.nan),
            "t_value": model.tvalues.get(var, np.nan),
            "p_value": p,
            "significance": significance_stars(p)
        })

    result = pd.DataFrame(rows)

    if not result.empty:
        result = safe_round_df(result, ["coef", "std_error", "t_value", "p_value"], 6)

    return result


def run_ols(formula, data, model_name):
    try:
        model = smf.ols(formula=formula, data=data).fit(cov_type="HC1")
        return model
    except Exception as e:
        add_section(f"ERROR IN MODEL: {model_name}", str(e))
        return None


