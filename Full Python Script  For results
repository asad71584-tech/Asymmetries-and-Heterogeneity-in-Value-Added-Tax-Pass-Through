def add_table(title, df, max_rows=None):
    if df is None or len(df) == 0:
        content = "No result available."
    else:
        if max_rows is not None:
            content = df.head(max_rows).to_string(index=False)
        else:
            content = df.to_string(index=False)

    add_section(title, content)


def safe_round_df(df, cols, digits=6):
    temp = df.copy()
    for col in cols:
        if col in temp.columns:
            temp[col] = pd.to_numeric(temp[col], errors="coerce").round(digits)
    return temp


