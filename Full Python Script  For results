# 15. ROBUSTNESS CHECKS
# ============================================================

def run_baseline_for_countries(country_list, specification):
    temp_data = baseline_data[
        baseline_data["country"].isin(country_list)
    ].copy()

    if temp_data.empty:
        return {
            "specification": specification,
            "countries": ", ".join(country_list),
            "during_coef": np.nan,
            "during_p_value": np.nan,
            "post_coef": np.nan,
            "post_p_value": np.nan,
            "observations": 0,
            "r_squared": np.nan
        }

    model = run_ols(
        baseline_formula,
        temp_data,
        specification
    )

    if model is None:
        return {
            "specification": specification,
            "countries": ", ".join(country_list),
            "during_coef": np.nan,
            "during_p_value": np.nan,
            "post_coef": np.nan,
            "post_p_value": np.nan,
            "observations": len(temp_data),
            "r_squared": np.nan
        }

    return {
        "specification": specification,
        "countries": ", ".join(country_list),
        "during_coef": model.params.get("germany_during", np.nan),
        "during_p_value": model.pvalues.get("germany_during", np.nan),
        "post_coef": model.params.get("germany_post", np.nan),
        "post_p_value": model.pvalues.get("germany_post", np.nan),
        "observations": int(model.nobs),
        "r_squared": model.rsquared
    }


robustness_rows = []

robustness_rows.append(
    run_baseline_for_countries(
        ["Germany"] + CONTROL_COUNTRIES,
        "Germany vs all controls"
    )
)

robustness_rows.append(
    run_baseline_for_countries(
        ["Germany", "Austria"],
        "Germany vs Austria only"
    )
)

for drop_country in CONTROL_COUNTRIES:
    remaining_controls = [c for c in CONTROL_COUNTRIES if c != drop_country]

    robustness_rows.append(
        run_baseline_for_countries(
            ["Germany"] + remaining_controls,
            f"Leave-one-out: drop {drop_country}"
        )
    )

robustness_results = pd.DataFrame(robustness_rows)

robustness_results = safe_round_df(
    robustness_results,
    ["during_coef", "during_p_value", "post_coef", "post_p_value", "r_squared"],
    6
)

add_table("ROBUSTNESS CHECKS", robustness_results)


