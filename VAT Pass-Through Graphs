VAT_REVERSAL = pd.Timestamp("2021-01-01")


# ============================================================
# 3. DATE / MONTH HELPERS
# ============================================================

def parse_month_value(value):
    """
    Try to convert a cell value into a monthly Timestamp.
    Returns None if the value is not a month.
    """

    if pd.isna(value):
        return None

    if isinstance(value, pd.Timestamp):
        return pd.Timestamp(value).replace(day=1)

    if hasattr(value, "year") and hasattr(value, "month"):
        try:
            return pd.Timestamp(year=value.year, month=value.month, day=1)
        except Exception:
            pass

    text = str(value).strip()

    if text == "":
        return None

    # Common Eurostat style examples:
    # 2018-01, 2018M01, 2018-01-01, 2018/01
    patterns = [
        r"^\d{4}-\d{2}$",
        r"^\d{4}M\d{2}$",
        r"^\d{4}-\d{2}-\d{2}$",
        r"^\d{4}/\d{2}$",
        r"^\d{2}/\d{4}$",
    ]

    if re.match(r"^\d{4}M\d{2}$", text):
        year = int(text[:4])
        month = int(text[-2:])
        return pd.Timestamp(year=year, month=month, day=1)

    for pattern in patterns:
        if re.match(pattern, text):
            parsed = pd.to_datetime(text.replace("M", "-"), errors="coerce")
            if not pd.isna(parsed):
                return pd.Timestamp(parsed).replace(day=1)

    # Try general parsing
    parsed = pd.to_datetime(text, errors="coerce")
    if not pd.isna(parsed):
        # Avoid treating random years like 2018 as monthly columns
        if parsed.year >= 2010 and parsed.year <= 2030:
            return pd.Timestamp(parsed).replace(day=1)

    return None


def is_month_cell(value):
    return parse_month_value(value) is not None


# ============================================================
# 4. COUNTRY HELPERS
# ============================================================

def clean_country_name(value):
    """Clean country names."""
    if pd.isna(value):
        return None

    text = str(value).strip()

    # Remove common Eurostat prefixes if present
    text = text.replace("Germany (until 1990 former territory of the FRG)", "Germany")

    country_map = {
        "germany": "Germany",
        "deutschland": "Germany",
        "de": "Germany",
        "austria": "Austria",
        "österreich": "Austria",
        "at": "Austria",
        "france": "France",
        "fr": "France",
        "belgium": "Belgium",
        "be": "Belgium",
        "netherlands": "Netherlands",
        "the netherlands": "Netherlands",
        "niederlande": "Netherlands",
        "nl": "Netherlands",
    }

    return country_map.get(text.lower(), text)


def looks_like_country(value):
    cleaned = clean_country_name(value)
    return cleaned in [TREATED_COUNTRY] + CONTROL_COUNTRIES


# ============================================================
# 5. ROBUST SHEET CLEANING
# ============================================================

def find_header_row(raw_df, sheet_name):
    """
    Find the row that contains monthly columns.
    This is needed because your Excel sheets have metadata rows before the real table.
    """

    best_row_index = None
    best_month_count = 0

    for idx in range(len(raw_df)):
        row_values = raw_df.iloc[idx].tolist()
        month_count = sum(is_month_cell(v) for v in row_values)

        if month_count > best_month_count:
            best_month_count = month_count
            best_row_index = idx

    if best_row_index is None or best_month_count < 6:
        raise ValueError(
            f"No header row with monthly columns found in sheet '{sheet_name}'. "
            f"Best month count was {best_month_count}."
        )

    return best_row_index


def find_country_column(data_df):
    """
    Find the column containing country names/codes.
    """

    best_col = None
    best_score = 0

    for col in data_df.columns:
        values = data_df[col].dropna().head(30).tolist()
        score = sum(looks_like_country(v) for v in values)

        if score > best_score:
            best_score = score
            best_col = col

    if best_col is None or best_score == 0:
        raise ValueError("Could not find country column.")

    return best_col


def clean_sheet(sheet_name, input_file):
    """
    Robustly clean one sheet:
    - Reads without headers
    - Finds the row with month columns
    - Uses that row as header
    - Finds country column
    - Converts wide monthly data to long panel
    """

    raw = pd.read_excel(input_file, sheet_name=sheet_name, header=None)
    raw = raw.dropna(how="all").dropna(axis=1, how="all").reset_index(drop=True)

    if raw.empty:
        raise ValueError(f"Sheet '{sheet_name}' is empty.")

    header_row = find_header_row(raw, sheet_name)

    headers = raw.iloc[header_row].tolist()
    data = raw.iloc[header_row + 1:].copy()
    data.columns = headers

    data = data.dropna(how="all").dropna(axis=1, how="all")

    # Make column names unique
    new_columns = []
    seen = {}
    for col in data.columns:
        col_text = str(col).strip()
        if col_text in seen:
            seen[col_text] += 1
            col_text = f"{col_text}_{seen[col_text]}"
        else:
            seen[col_text] = 0
        new_columns.append(col_text)

    data.columns = new_columns

    month_cols = []
    month_map = {}

    for col in data.columns:
        parsed_month = parse_month_value(col)
        if parsed_month is not None:
            month_cols.append(col)
            month_map[col] = parsed_month

    if not month_cols:
        raise ValueError(f"No monthly columns found after header detection in '{sheet_name}'.")

    country_col = find_country_column(data)

    keep_cols = [country_col] + month_cols
    temp = data[keep_cols].copy()

    temp = temp.rename(columns={country_col: "country"})
    temp["country"] = temp["country"].apply(clean_country_name)

    temp = temp[temp["country"].isin([TREATED_COUNTRY] + CONTROL_COUNTRIES)]

    long_df = temp.melt(
        id_vars=["country"],
        value_vars=month_cols,
        var_name="month_original",
        value_name="hicp_index",
    )

    long_df["month"] = long_df["month_original"].map(month_map)
    long_df["hicp_index"] = pd.to_numeric(long_df["hicp_index"], errors="coerce")
    long_df["category"] = sheet_name

    long_df = long_df.dropna(subset=["country", "month", "hicp_index"])

    return long_df[["country", "month", "category", "hicp_index"]]


def load_hicp_panel(input_file):
    """Load all selected category sheets into one panel."""

    xls = pd.ExcelFile(input_file)
    available_sheets = xls.sheet_names

    print("\nAvailable sheets:")
    for sheet in available_sheets:
        print(f" - {sheet}")

    panel_parts = []

    for sheet in ALL_SELECTED_CATEGORIES:
        if sheet not in available_sheets:
            print(f"WARNING: Sheet not found: {sheet}")
            continue

        try:
            cleaned = clean_sheet(sheet, input_file)
            panel_parts.append(cleaned)
            print(f"Cleaned sheet: {sheet} | rows: {len(cleaned)}")

        except Exception as e:
            print(f"WARNING: Could not clean sheet {sheet}: {e}")

    if not panel_parts:
        raise RuntimeError("No sheets could be cleaned. Please check Excel structure.")

    panel = pd.concat(panel_parts, ignore_index=True)
    panel = panel.sort_values(["country", "category", "month"]).reset_index(drop=True)

    return panel


# ============================================================
# 6. DATA PREPARATION FOR GRAPHS
# ============================================================

def prepare_core_food_trend(panel):
    """Average selected food categories by country and month."""

    core = panel[panel["category"].isin(CORE_FOOD_CATEGORIES)].copy()

    country_month = (
        core.groupby(["country", "month"], as_index=False)["hicp_index"]
        .mean()
        .rename(columns={"hicp_index": "core_food_hicp"})
    )

    return country_month


# ============================================================
# 7. GRAPH STYLE HELPERS
# ============================================================

def add_policy_lines(ax):
    """Add VAT cut and reversal lines."""

    ax.axvline(
        VAT_CUT_START,
        linestyle="--",
        linewidth=1.5,
        color="black",
        alpha=0.75,
    )

    ax.axvline(
        VAT_REVERSAL,
        linestyle="--",
        linewidth=1.5,
        color="black",
        alpha=0.75,
    )

    ymin, ymax = ax.get_ylim()

    ax.text(
        VAT_CUT_START,
        ymax,
        "VAT cut begins\nJul 2020",
        rotation=90,
        va="top",
        ha="right",
        fontsize=9,
    )

    ax.text(
        VAT_REVERSAL,
        ymax,
        "VAT reversal\nJan 2021",
        rotation=90,
        va="top",
        ha="right",
        fontsize=9,
    )


def apply_clean_style(ax, title, subtitle=None, y_label="HICP index", x_label="Month"):
    """Clean academic graph style."""

    ax.set_title(title, fontsize=14, fontweight="bold", pad=14)

    if subtitle:
        ax.text(
            0,
            1.03,
            subtitle,
            transform=ax.transAxes,
            fontsize=10,
            va="bottom",
            ha="left",
        )

    ax.set_xlabel(x_label, fontsize=11)
    ax.set_ylabel(y_label, fontsize=11)

    ax.grid(True, axis="y", alpha=0.3)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.tick_params(axis="x", labelrotation=45)
    ax.legend(frameon=False, fontsize=10)


def save_figure(fig, filename):
    """Save figure as PNG and PDF."""

    png_path = OUTPUT_DIR / f"{filename}.png"
    pdf_path = OUTPUT_DIR / f"{filename}.pdf"

    fig.savefig(png_path, dpi=300, bbox_inches="tight")
    fig.savefig(pdf_path, bbox_inches="tight")

    print(f"Saved: {png_path}")
    print(f"Saved: {pdf_path}")


# ============================================================
# 8. FIGURE 1
# ============================================================

def create_figure_1(country_month):
    """Core food HICP trend: Germany vs average controls."""

    germany = country_month[country_month["country"] == TREATED_COUNTRY].copy()

    controls = (
        country_month[country_month["country"].isin(CONTROL_COUNTRIES)]
        .groupby("month", as_index=False)["core_food_hicp"]
        .mean()
        .rename(columns={"core_food_hicp": "control_average"})
    )

    plot_df = germany.merge(controls, on="month", how="inner")

    fig, ax = plt.subplots(figsize=(10.5, 5.8))

    ax.plot(
        plot_df["month"],
        plot_df["core_food_hicp"],
        linewidth=2.5,
        marker="o",
        markersize=3,
        label="Germany",
    )

    ax.plot(
        plot_df["month"],
        plot_df["control_average"],
        linewidth=2.5,
        marker="o",
        markersize=3,
        label="Average controls",
    )

    add_policy_lines(ax)

    apply_clean_style(
        ax=ax,
        title="Figure 1: Core Food HICP Trend in Germany and Control Countries",
        subtitle="Germany compared with the average of Austria, France, Belgium and the Netherlands",
        y_label="Core food HICP index",
        x_label="Month",
    )

    fig.tight_layout()
    save_figure(fig, "Figure_1_Core_Food_Germany_vs_Control_Average")
    plt.close(fig)


