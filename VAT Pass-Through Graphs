# 11. APPENDIX FIGURE A2
# ============================================================

def create_appendix_figure_a2():
    """Category-specific during-cut and post-reversal coefficients."""

    category_df = pd.DataFrame(
        {
            "category": [
                "Bread and cereals",
                "Bread",
                "Meat",
                "Milk, cheese and eggs",
                "Clothing",
            ],
            "during": [-0.003352, -0.001855, -0.004209, -0.002832, -0.007896],
            "post": [0.002719, 0.002819, 0.001883, 0.005184, 0.004936],
        }
    )

    fig, ax = plt.subplots(figsize=(10.5, 6.2))

    y_pos = np.arange(len(category_df))
    bar_height = 0.36

    ax.barh(
        y_pos - bar_height / 2,
        category_df["during"],
        height=bar_height,
        label="During VAT cut",
        edgecolor="black",
        linewidth=0.7,
    )

    ax.barh(
        y_pos + bar_height / 2,
        category_df["post"],
        height=bar_height,
        label="Post-reversal",
        edgecolor="black",
        linewidth=0.7,
    )

    ax.axvline(0, color="black", linewidth=1.0)

    ax.set_yticks(y_pos)
    ax.set_yticklabels(category_df["category"], fontsize=10)

    ax.set_title(
        "Appendix Figure A2: Category-Specific During-Cut and Post-Reversal Coefficients",
        fontsize=14,
        fontweight="bold",
        pad=14,
    )

    ax.text(
        0,
        1.03,
        "Separate category regressions; dependent variable is monthly ΔlnHICP",
        transform=ax.transAxes,
        fontsize=10,
        va="bottom",
        ha="left",
    )

    ax.set_xlabel("Coefficient", fontsize=11)
    ax.grid(True, axis="x", alpha=0.3)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.legend(frameon=False, fontsize=10, loc="lower right")

    for i, row in category_df.iterrows():
        ax.text(
            row["during"],
            i - bar_height / 2,
            f"{row['during']:.4f}",
            va="center",
            ha="right" if row["during"] < 0 else "left",
            fontsize=9,
        )

        ax.text(
            row["post"],
            i + bar_height / 2,
            f"{row['post']:.4f}",
            va="center",
            ha="left" if row["post"] > 0 else "right",
            fontsize=9,
        )

    fig.tight_layout()
    save_figure(fig, "Appendix_Figure_A2_Category_Specific_Coefficients")
    plt.close(fig)


