# 9. FIGURE 2
# ============================================================

def create_figure_2():
    """Baseline coefficients with 95% confidence intervals."""

    coef_df = pd.DataFrame(
        {
            "variable": ["Germany × During", "Germany × Post"],
            "coefficient": [-0.003062, 0.003151],
            "std_error": [0.001461, 0.001214],
            "p_value": [0.036, 0.009],
        }
    )

    coef_df["ci_low"] = coef_df["coefficient"] - 1.96 * coef_df["std_error"]
    coef_df["ci_high"] = coef_df["coefficient"] + 1.96 * coef_df["std_error"]

    fig, ax = plt.subplots(figsize=(8.5, 5.5))

    x_pos = np.arange(len(coef_df))

    ax.bar(
        x_pos,
        coef_df["coefficient"],
        width=0.55,
        edgecolor="black",
        linewidth=0.8,
    )

    yerr = [
        coef_df["coefficient"] - coef_df["ci_low"],
        coef_df["ci_high"] - coef_df["coefficient"],
    ]

    ax.errorbar(
        x_pos,
        coef_df["coefficient"],
        yerr=yerr,
        fmt="none",
        ecolor="black",
        elinewidth=1.4,
        capsize=6,
        label="95% confidence interval",
    )

    ax.axhline(0, color="black", linewidth=1.0)

    ax.set_xticks(x_pos)
    ax.set_xticklabels(coef_df["variable"], fontsize=11)

    for i, row in coef_df.iterrows():
        label = f"{row['coefficient']:.4f}\np={row['p_value']:.3f}"
        y_value = row["coefficient"]

        if y_value >= 0:
            va = "bottom"
            offset = 0.00025
        else:
            va = "top"
            offset = -0.00025

        ax.text(
            i,
            y_value + offset,
            label,
            ha="center",
            va=va,
            fontsize=10,
        )

    ax.set_title(
        "Figure 2: Baseline During-Cut and Post-Reversal Coefficients",
        fontsize=14,
        fontweight="bold",
        pad=14,
    )

    ax.text(
        0,
        1.03,
        "Pooled food fixed-effects model; dependent variable is monthly ΔlnHICP",
        transform=ax.transAxes,
        fontsize=10,
        va="bottom",
        ha="left",
    )

    ax.set_ylabel("Coefficient", fontsize=11)
    ax.grid(True, axis="y", alpha=0.3)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.legend(frameon=False, fontsize=10, loc="lower right")

    fig.tight_layout()
    save_figure(fig, "Figure_2_Baseline_Coefficients")
    plt.close(fig)


