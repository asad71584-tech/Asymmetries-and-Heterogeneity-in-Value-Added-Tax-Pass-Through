def main():
    print("\n" + "=" * 70)
    print("STARTING VAT PASS-THROUGH GRAPH CREATION")
    print("=" * 70)

    print(f"\nInput file:\n{INPUT_FILE}")
    print(f"\nOutput folder:\n{OUTPUT_DIR}")

    panel = load_hicp_panel(INPUT_FILE)

    print("\nPanel overview:")
    print(panel.head())
    print(f"\nTotal rows: {len(panel)}")
    print(f"Countries: {sorted(panel['country'].unique())}")
    print(f"Categories: {sorted(panel['category'].unique())}")
    print(f"Date range: {panel['month'].min().date()} to {panel['month'].max().date()}")

    country_month = prepare_core_food_trend(panel)

    create_figure_1(country_month)
    create_figure_2()
    create_appendix_figure_a1(country_month)
    create_appendix_figure_a2()

    print("\n" + "=" * 70)
    print("Graph creation completed.")
    print("=" * 70)

    print("\nCreated PNG files:")
    print("1. Figure_1_Core_Food_Germany_vs_Control_Average.png")
    print("2. Figure_2_Baseline_Coefficients.png")
    print("3. Appendix_Figure_A1_Core_Food_Germany_vs_Austria.png")
    print("4. Appendix_Figure_A2_Category_Specific_Coefficients.png")



if __name__ == "__main__":
    main()
