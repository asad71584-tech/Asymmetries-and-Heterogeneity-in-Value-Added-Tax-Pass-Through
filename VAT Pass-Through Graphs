import re

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt


INPUT_FILE = r"D:\MSEP\4th\Pub. Eco. Reseach M\Data\3rd\meat, bread, milk cloths...xlsx"

TREATED_COUNTRY = "Germany"
CONTROL_COUNTRIES = ["Austria", "France", "Belgium", "Netherlands"]

CORE_FOOD_CATEGORIES = [
    "Bread",
    "Bread and cereals",
    "Meat",
    "Milk, cheese and eggs",
]

ALL_SELECTED_CATEGORIES = [
    "Bread and cereals",
    "Bread",
    "Meat",
    "Milk, cheese and eggs",
    "Clothing",
]

VAT_CUT_START = pd.Timestamp("2020-07-01")
VAT_REVERSAL = pd.Timestamp("2021-01-01")


def parse_month_value(value):
    if pd.isna(value):
        return None

    if isinstance(value, pd.Timestamp):
        return value.replace(day=1)

    if hasattr(value, "year") and hasattr(value, "month"):
        try:
            return pd.Timestamp(year=value.year, month=value.month, day=1)
        except Exception:
            pass

    text = str(value).strip()

    if text == "":
        return None

    if re.match(r"^\d{4}M\d{2}$", text):
        return pd.Timestamp(year=int(text[:4]), month=int(text[-2:]), day=1)

    if re.match(r"^\d{4}-\d{2}$", text):
        return pd.to_datetime(text + "-01", errors="coerce")

    if re.match(r"^\d{4}-\d{2}-\d{2}$", text):
        return pd.to_datetime(text, errors="coerce").replace(day=1)

    parsed = pd.to_datetime(text, errors="coerce")

    if pd.isna(parsed):
        return None

    if 2010 <= parsed.year <= 2030:
        return parsed.replace(day=1)

    return None


def is_month_cell(value):
    return parse_month_value(value) is not None


def clean_country_name(value):
    if pd.isna(value):
        return None

    text = str(value).strip()

    country_map = {
        "germany": "Germany",
        "deutschland": "Germany",
        "de": "Germany",
        "austria": "Austria",
        "österreich": "Austria",
        "at": "Austria",
        "france": "France",
        "fr": "France",
        "belgium": "Belgium",
        "be": "Belgium",
        "netherlands": "Netherlands",
        "the netherlands": "Netherlands",
        "niederlande": "Netherlands",
        "nl": "Netherlands",
    }

    return country_map.get(text.lower(), text)


def looks_like_country(value):
    return clean_country_name(value) in [TREATED_COUNTRY] + CONTROL_COUNTRIES


def find_header_row(raw_df):
    best_row = None
    best_count = 0

    for idx in range(len(raw_df)):
        count = sum(is_month_cell(v) for v in raw_df.iloc[idx].tolist())

        if count > best_count:
            best_count = count
            best_row = idx

    if best_row is None or best_count < 6:
        raise ValueError("No monthly header row found.")

    return best_row


def find_country_column(df):
    best_col = None
    best_score = 0

    for col in df.columns:
        values = df[col].dropna().head(40).tolist()
        score = sum(looks_like_country(v) for v in values)

        if score > best_score:
            best_score = score
            best_col = col

    if best_col is None:
        raise ValueError("No country column found.")

    return best_col


def clean_sheet(sheet_name):
    raw = pd.read_excel(INPUT_FILE, sheet_name=sheet_name, header=None)
    raw = raw.dropna(how="all").dropna(axis=1, how="all").reset_index(drop=True)

    header_row = find_header_row(raw)

    headers = raw.iloc[header_row].tolist()
    data = raw.iloc[header_row + 1:].copy()
    data.columns = [str(h).strip() for h in headers]
    data = data.dropna(how="all").dropna(axis=1, how="all")

    month_cols = []
    month_map = {}

    for col in data.columns:
        month = parse_month_value(col)

        if month is not None:
            month_cols.append(col)
            month_map[col] = month

    country_col = find_country_column(data)

    temp = data[[country_col] + month_cols].copy()
    temp = temp.rename(columns={country_col: "country"})
    temp["country"] = temp["country"].apply(clean_country_name)
    temp = temp[temp["country"].isin([TREATED_COUNTRY] + CONTROL_COUNTRIES)]

    long_df = temp.melt(
        id_vars="country",
        value_vars=month_cols,
        var_name="month_raw",
        value_name="hicp_index",
    )

    long_df["month"] = long_df["month_raw"].map(month_map)
    long_df["hicp_index"] = pd.to_numeric(long_df["hicp_index"], errors="coerce")
    long_df["category"] = sheet_name
    long_df = long_df.dropna(subset=["country", "month", "hicp_index"])

    return long_df[["country", "month", "category", "hicp_index"]]


def load_panel():
    parts = []

    for sheet in ALL_SELECTED_CATEGORIES:
        try:
            df = clean_sheet(sheet)
            parts.append(df)
            print(f"{sheet}: {len(df)} rows")
        except Exception as e:
            print(f"{sheet}: skipped ({e})")

    if not parts:
        raise RuntimeError("No sheets could be loaded.")

    panel = pd.concat(parts, ignore_index=True)
    panel = panel.sort_values(["country", "category", "month"]).reset_index(drop=True)

    return panel


def prepare_core_food(panel):
    core = panel[panel["category"].isin(CORE_FOOD_CATEGORIES)].copy()

    return (
        core.groupby(["country", "month"], as_index=False)["hicp_index"]
        .mean()
        .rename(columns={"hicp_index": "hicp_index"})
    )


def mark_policy_dates(ax):
    ax.axvline(VAT_CUT_START, linestyle="--", color="black", linewidth=1.2, alpha=0.7)
    ax.axvline(VAT_REVERSAL, linestyle="--", color="black", linewidth=1.2, alpha=0.7)

    ymin, ymax = ax.get_ylim()
    y_pos = ymax - (ymax - ymin) * 0.06

    ax.text(
        VAT_CUT_START,
        y_pos,
        "VAT cut\nJul 2020",
        rotation=90,
        ha="right",
        va="top",
        fontsize=8,
    )

    ax.text(
        VAT_REVERSAL,
        y_pos,
        "Reversal\nJan 2021",
        rotation=90,
        ha="right",
        va="top",
        fontsize=8,
    )


def format_line_chart(ax, title):
    ax.set_title(title, fontsize=13, fontweight="bold", pad=12)
    ax.set_xlabel("Month", fontsize=10)
    ax.set_ylabel("HICP index", fontsize=10)
    ax.grid(axis="y", alpha=0.25)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.tick_params(axis="x", labelrotation=45, labelsize=8)
    ax.tick_params(axis="y", labelsize=9)
    ax.legend(frameon=False, fontsize=9, loc="upper left")


def graph_germany_vs_controls(country_month):
    germany = country_month[country_month["country"] == "Germany"].copy()

    controls = (
        country_month[country_month["country"].isin(CONTROL_COUNTRIES)]
        .groupby("month", as_index=False)["hicp_index"]
        .mean()
        .rename(columns={"hicp_index": "control_average"})
    )

    plot_df = germany.merge(controls, on="month", how="inner")

    fig, ax = plt.subplots(figsize=(9, 4.8))

    ax.plot(
        plot_df["month"],
        plot_df["hicp_index"],
        marker="o",
        markersize=2.5,
        linewidth=2,
        label="Germany",
    )

    ax.plot(
        plot_df["month"],
        plot_df["control_average"],
        marker="o",
        markersize=2.5,
        linewidth=2,
        label="Average controls",
    )

    mark_policy_dates(ax)
    format_line_chart(ax, "Descriptive HICP Trends: Germany vs Control Average")

    fig.tight_layout()
    plt.show()


def graph_baseline_coefficients():
    df = pd.DataFrame(
        {
            "variable": ["Germany × During", "Germany × Post"],
            "coefficient": [-0.003062, 0.003151],
            "std_error": [0.001461, 0.001214],
            "p_value": [0.036, 0.009],
        }
    )

    df["ci_low"] = df["coefficient"] - 1.96 * df["std_error"]
    df["ci_high"] = df["coefficient"] + 1.96 * df["std_error"]

    fig, ax = plt.subplots(figsize=(7.5, 4.8))

    x = np.arange(len(df))

    ax.bar(x, df["coefficient"], width=0.5, edgecolor="black", linewidth=0.8)

    ax.errorbar(
        x,
        df["coefficient"],
        yerr=[
            df["coefficient"] - df["ci_low"],
            df["ci_high"] - df["coefficient"],
        ],
        fmt="none",
        ecolor="black",
        elinewidth=1.2,
        capsize=5,
    )

    ax.axhline(0, color="black", linewidth=1)

    ax.set_xticks(x)
    ax.set_xticklabels(df["variable"], fontsize=10)
    ax.set_ylabel("Coefficient", fontsize=10)
    ax.set_title("Baseline Regression Coefficients", fontsize=13, fontweight="bold", pad=12)

    for i, row in df.iterrows():
        label = f"{row['coefficient']:.4f}\np={row['p_value']:.3f}"
        offset = 0.00025 if row["coefficient"] > 0 else -0.00025
        va = "bottom" if row["coefficient"] > 0 else "top"

        ax.text(i, row["coefficient"] + offset, label, ha="center", va=va, fontsize=9)

    ax.grid(axis="y", alpha=0.25)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)

    fig.tight_layout()
    plt.show()


def graph_germany_vs_austria(country_month):
    plot_df = country_month[country_month["country"].isin(["Germany", "Austria"])].copy()

    fig, ax = plt.subplots(figsize=(9, 4.8))

    for country in ["Germany", "Austria"]:
        temp = plot_df[plot_df["country"] == country]

        ax.plot(
            temp["month"],
            temp["hicp_index"],
            marker="o",
            markersize=2.5,
            linewidth=2,
            label=country,
        )

    mark_policy_dates(ax)
    format_line_chart(ax, "Robustness Check: Germany vs Austria")

    fig.tight_layout()
    plt.show()


def graph_category_coefficients():
    df = pd.DataFrame(
        {
            "category": [
                "Bread and cereals",
                "Bread",
                "Meat",
                "Milk, cheese and eggs",
                "Clothing",
            ],
            "during": [-0.003352, -0.001855, -0.004209, -0.002832, -0.007896],
            "post": [0.002719, 0.002819, 0.001883, 0.005184, 0.004936],
        }
    )

    fig, ax = plt.subplots(figsize=(9, 5))

    y = np.arange(len(df))
    h = 0.35

    ax.barh(
        y - h / 2,
        df["during"],
        height=h,
        edgecolor="black",
        linewidth=0.7,
        label="During VAT cut",
    )

    ax.barh(
        y + h / 2,
        df["post"],
        height=h,
        edgecolor="black",
        linewidth=0.7,
        label="Post-reversal",
    )

    ax.axvline(0, color="black", linewidth=1)

    ax.set_yticks(y)
    ax.set_yticklabels(df["category"], fontsize=9)
    ax.set_xlabel("Coefficient", fontsize=10)
    ax.set_title("Category-Specific Coefficient Estimates", fontsize=13, fontweight="bold", pad=12)

    ax.grid(axis="x", alpha=0.25)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.legend(frameon=False, fontsize=9, loc="lower right")

    fig.tight_layout()
    plt.show()


def main():
    panel = load_panel()
    country_month = prepare_core_food(panel)

    graph_germany_vs_controls(country_month)
    graph_baseline_coefficients()
    graph_category_coefficients()
    graph_germany_vs_austria(country_month)


if __name__ == "__main__":
    main()
