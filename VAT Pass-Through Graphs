def create_appendix_figure_a1(country_month):
    """Core food HICP trend: Germany vs Austria."""

    plot_df = country_month[
        country_month["country"].isin(["Germany", "Austria"])
    ].copy()

    fig, ax = plt.subplots(figsize=(10.5, 5.8))

    for country in ["Germany", "Austria"]:
        temp = plot_df[plot_df["country"] == country].copy()

        ax.plot(
            temp["month"],
            temp["core_food_hicp"],
            linewidth=2.5,
            marker="o",
            markersize=3,
            label=country,
        )

    add_policy_lines(ax)

    apply_clean_style(
        ax=ax,
        title="Appendix Figure A1: Core Food HICP Trend in Germany and Austria",
        subtitle="Austria is shown separately as an important comparison country",
        y_label="Core food HICP index",
        x_label="Month",
    )

    fig.tight_layout()
    save_figure(fig, "Appendix_Figure_A1_Core_Food_Germany_vs_Austria")
    plt.close(fig)


